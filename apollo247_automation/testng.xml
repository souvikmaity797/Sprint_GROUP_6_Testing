
<!--
  TestNG Suite – Apollo247 Cross-Browser Parallel Execution
  =========================================================

  What runs in PARALLEL  : 3 browsers (Chrome, Firefox, Edge) — one thread each
  What runs SEQUENTIALLY : 7 scenarios inside each browser, one after another

  Result: exactly 3 browser windows open at a time

  ┌──────────────────────────────────────────────────────────────┐
  │  Thread 1 (Chrome)  → TC_01 → TC_02 → TC_03 → ... → TC_07  │
  │  Thread 2 (Firefox) → TC_01 → TC_02 → TC_03 → ... → TC_07  │
  │  Thread 3 (Edge)    → TC_01 → TC_02 → TC_03 → ... → TC_07  │
  └──────────────────────────────────────────────────────────────┘

  To run only one browser:
    Right-click RunnerIO → Run As → TestNG  (uses default system browser)
    or: mvn test -Dbrowser=chrome
-->

<suite name="Apollo247 - Cross-Browser Suite"
       parallel="tests"
       thread-count="3"
       verbose="1">

    <!-- ── CHROME ─────────────────────────────────────────────────────────── -->
    <test name="Chrome Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="testrunner.RunnerIO"/>
        </classes>
    </test>



</suite>